# ==================================================
# Dependencies
# ==================================================
node_modules/
frontend/node_modules/
backend/node_modules/

# ==================================================
# Build outputs
# ==================================================
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/
backend/dist/

# ==================================================
# Environment files
# ==================================================
.env
.env.*
*.local

# Keep example environment files
!.env.example
!.env.*.example

# ==================================================
# Logs
# ==================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==================================================
# Test coverage
# ==================================================
coverage/
frontend/coverage/
backend/coverage/

# ==================================================
# Uploaded and temporary files
# ==================================================
backend/storage/uploads/*
backend/storage/temp/*

# Keep empty folders
!backend/storage/uploads/.gitkeep
!backend/storage/temp/.gitkeep

# ==================================================
# Database backups
# ==================================================
*.sql
*.dump
*.backup

# ==================================================
# Editor and IDE files
# ==================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==================================================
# Operating system files
# ==================================================
.DS_Store
Thumbs.db

# ==================================================
# History files
# ==================================================
.history/
# Server Configuration
NODE_ENV=development
PORT=5001

# Database Configuration (Example for PostgreSQL)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=flcms_db
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_for_development

# Initial Admin User Credentials (for seeding)
ADMIN_INSTITUTIONAL_ID=
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_FULL_NAME=
{
  "name": "backend",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Backend API for Faculty Laboratory Chemical Management System",
  "main": "src/server.js",
  "scripts": {
    "dev": "npm run db:migrate:dev && npm run db:seed:dev && cross-env NODE_ENV=development node --watch --watch-preserve-output src/server.js",
    "start": "npm run db:migrate:prod && npm run db:seed:prod && cross-env NODE_ENV=production node src/server.js",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "lint": "eslint .",
    "dev:test": "cross-env NODE_ENV=test node --watch --watch-preserve-output src/server.js",
    "start:test": "npm run db:migrate:test && npm run db:seed:test && cross-env NODE_ENV=test node src/server.js",
    "db:migration:create": "sequelize-cli migration:generate",
    "db:migrate:dev": "cross-env NODE_ENV=development sequelize-cli db:migrate",
    "db:migrate:status:dev": "cross-env NODE_ENV=development sequelize-cli db:migrate:status",
    "db:migrate:undo:dev": "cross-env NODE_ENV=development sequelize-cli db:migrate:undo",
    "db:migrate:test": "cross-env NODE_ENV=test sequelize-cli db:migrate",
    "db:migrate:undo:test": "cross-env NODE_ENV=test sequelize-cli db:migrate:undo",
    "db:migrate:undo:prod": "cross-env NODE_ENV=production sequelize-cli db:migrate:undo",
    "db:migrate:prod": "cross-env NODE_ENV=production sequelize-cli db:migrate",
    "db:seed:create": "sequelize-cli seed:generate",
    "db:seed:dev": "cross-env NODE_ENV=development sequelize-cli db:seed:all",
    "db:seed:test": "cross-env NODE_ENV=test sequelize-cli db:seed:all",
    "db:seed:prod": "cross-env NODE_ENV=production sequelize-cli db:seed:all",
    "perf:health": "autocannon -c 20 -d 20 http://localhost:5000/api/health"
  },
  "keywords": [
    "chemical-management",
    "express",
    "sequelize",
    "postgresql"
  ],
  "author": "CMS-FOT Project Team",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autocannon": "^8.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "uuid": "^9.0.1",
    "vitest": "^4.1.10"
  }
}
